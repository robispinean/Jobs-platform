{
  "env": {
    "node": true
  },
  "extends": [
    "airbnb-base"
  ],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "no-console": "off",
    "no-underscore-dangle": "off",
    "no-unused-vars": "off",
    "max-len": "off",
    "no-restricted-syntax": ["error", "BinaryExpression[operator='in']"]
  },
  "settings": {
    "import/extensions": "off",
    "import/resolver": {
      "node": {
        "extensions": [
          ".js"
        ]
      }
    }
  }
}